# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord Channel ID where reminders are sent and photos are monitored
DISCORD_CHANNEL_ID=your_channel_id_here

# Anthropic API Key (from https://console.anthropic.com) — optional fallback
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API Key (from https://aistudio.google.com/apikey) — primary AI engine
GEMINI_API_KEY=your_gemini_api_key_here

# Timezone for scheduled reminders (e.g., America/New_York, Europe/London, US/Central)
TIMEZONE=America/Chicago
